<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Date + Level row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvDay"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="March 2026 — Day 9"
                android:textColor="@color/text_grey"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LVL 1"
                android:textColor="@color/yellow_primary"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Commoner"
            android:textColor="@color/text_white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Earn achievements to unlock special titles"
            android:textColor="@color/text_grey"
            android:textSize="12sp"
            android:layout_marginBottom="14dp"/>

        <!-- EXP Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_card"
            android:padding="14dp"
            android:orientation="vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="EXPERIENCE"
                    android:textColor="@color/text_grey"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvExpProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 500 XP"
                    android:textColor="@color/yellow_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressEXP"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="500"
                android:progress="0"
                android:progressTint="@color/yellow_primary"
                android:progressBackgroundTint="@color/bg_dark"/>
        </LinearLayout>

        <!-- Budget card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_card"
            android:padding="14dp"
            android:orientation="vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MONTHLY BUDGET"
                android:textColor="@color/text_grey"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Budget"
                        android:textColor="@color/text_grey"
                        android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/tvBudget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0.00"
                        android:textColor="@color/text_white"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spent"
                        android:textColor="@color/text_grey"
                        android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/tvSpent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0.00"
                        android:textColor="@color/color_spent"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvSpentPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0% of budget"
                        android:textColor="@color/text_grey"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Savings"
                        android:textColor="@color/text_grey"
                        android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/tvSavings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RM 0.00"
                        android:textColor="@color/color_savings"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvSavingsStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Safe zone"
                        android:textColor="@color/color_success"
                        android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Savings Goal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_card"
            android:padding="14dp"
            android:orientation="vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvSavingsGoal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SAVINGS GOAL: RM 0"
                    android:textColor="@color/text_grey"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvSavingsGoalPct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/color_savings"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressSavingsGoal"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/color_savings"
                android:progressBackgroundTint="@color/bg_dark"/>
        </LinearLayout>

        <!-- Boss bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_card"
            android:padding="14dp"
            android:orientation="vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👾 BUDGET BOSS"
                android:textColor="@color/color_spent"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <ProgressBar
                android:id="@+id/progressBoss"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:max="1000"
                android:progress="0"
                android:progressTint="@color/color_spent"
                android:progressBackgroundTint="@color/bg_dark"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvBossHealth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RM 0 / RM 0"
                    android:textColor="@color/text_white"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvBossMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keep it up!"
                    android:textColor="@color/color_success"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Demo buttons -->
        <Button
            android:id="@+id/btnAdvanceDay"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="⏭ NEXT DAY (DEMO)"
            android:textColor="@color/yellow_primary"
            android:textSize="12sp"
            android:backgroundTint="@color/bg_card"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnAdvanceMonth"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="⏭ NEXT MONTH (DEMO)"
            android:textColor="@color/yellow_primary"
            android:textSize="12sp"
            android:backgroundTint="@color/bg_card"
            android:visibility="gone"
            android:layout_marginBottom="80dp"/>

    </LinearLayout>
</ScrollView>