<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎮"
            android:textSize="48sp"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Demo Mode Setup"
            android:textColor="@color/text_white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Separate sandbox — real progress untouched"
            android:textColor="@color/text_grey"
            android:textSize="13sp"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MONTHLY BUDGET (RM)"
            android:textColor="@color/text_grey"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etDemoBudget"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/bg_card"
            android:paddingHorizontal="16dp"
            android:hint="e.g. 1500"
            android:inputType="numberDecimal"
            android:textColor="@color/text_white"
            android:textColorHint="@color/text_grey"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SAVINGS GOAL (RM) — optional"
            android:textColor="@color/text_grey"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etDemoGoal"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/bg_card"
            android:paddingHorizontal="16dp"
            android:hint="e.g. 500"
            android:inputType="numberDecimal"
            android:textColor="@color/text_white"
            android:textColorHint="@color/text_grey"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="START DATE (budget resets on this day each month)"
            android:textColor="@color/text_grey"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <Spinner
                android:id="@+id/spinnerDemoStartDay"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@color/bg_card"/>

            <Spinner
                android:id="@+id/spinnerDemoStartMonth"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:layout_marginEnd="6dp"
                android:background="@color/bg_card"/>

            <Spinner
                android:id="@+id/spinnerDemoStartYear"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@color/bg_card"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnStartDemo"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="▶  START DEMO"
            android:textColor="@color/bg_dark"
            android:textStyle="bold"
            android:textSize="16sp"
            android:backgroundTint="@color/yellow_primary"/>

    </LinearLayout>
</ScrollView>